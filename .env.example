# ──────────────────────────────────────────────────────────────
# CheckMyRep Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ──────────────────────────────────────────────────────────────

# ── Government Data APIs ──────────────────────────────────────
CONGRESS_GOV_API_KEY="your_congress_gov_api_key"
GOOGLE_CIVIC_API_KEY="your_google_civic_api_key"
GOVINFO_API_KEY="your_govinfo_api_key"
LDA_API_KEY="your_lda_api_key"
LEGISCAN_API_KEY="your_legiscan_api_key"
OPENFEC_API_KEY="your_openfec_api_key"
OPENSTATES_API_KEY="your_openstates_api_key"

# ── Stripe (Payment Processing) ──────────────────────────────
# Get keys at https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Lob (Physical Mail) ──────────────────────────────────────
# Get key at https://dashboard.lob.com
LOB_API_KEY="test_..."
LOB_WEBHOOK_SECRET="your_lob_webhook_secret"

# ── Supabase (Auth & Database) ────────────────────────────────
# Get from https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key"

# ── Email (Optional — server-side only) ───────────────────────
RESEND_API_KEY="re_..."
SENDGRID_API_KEY="SG...."
EMAIL_FROM="noreply@checkmyrep.us"

# ── Regulations.gov (Optional) ────────────────────────────────
REGULATIONS_GOV_API_KEY="your_regulations_gov_api_key"

# ── Rate Limiting ─────────────────────────────────────────────
# Max requests per window (defaults shown)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=30
